# .env.example — copy to .env and fill in your real values
# NEVER commit .env to version control

# ── Twilio (WhatsApp) ───────────────────────────────────────────
# Get these from twilio.com → Console → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=<your_auth_token>
# Twilio sandbox number from: Messaging → Try it out → Send a WhatsApp message
TWILIO_WHATSAPP_FROM=whatsapp:+<twilio_sandbox_number>
# Sandbox join keyword — shown in the Twilio Console sandbox page (e.g. "join example-word")
TWILIO_SANDBOX_KEYWORD=<your_sandbox_keyword>

# ── Ollama (local Llama model) ──────────────────────────────────
LLAMA_API_URL=http://localhost:11434/api/generate
LLAMA_MODEL=<your_model_name>
LLAMA_TIMEOUT=180

# ── Database ────────────────────────────────────────────────────
DB_PATH=./data/weather_broadcast.db

# ── Webhook ──────────────────────────────────────────────────────
WEBHOOK_ENABLED=true
WEBHOOK_PORT=5000
NGROK_ENABLED=false
TWILIO_SIGNATURE_VALIDATION=false   # set true in production
WEBHOOK_BASE_URL=https://your-ngrok-url.ngrok-free.dev

# ── Admin & Observability ────────────────────────────────────────
ADMIN_PHONE=+<your_phone_number>
METRICS_API_KEY=<generate_a_random_string>
HALLUCINATION_CHECK_ENABLED=true
SAFETY_CHECK_ENABLED=true
